# ── Groq ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant
# on_demand llama-3.1-8b-instant TPM limit is 6000 per request
GROQ_MAX_REQUEST_TOKENS=5500

# ── Weaviate ───────────────────────────────────────────────────────────────
RAG_WEAVIATE_URL=http://localhost:8080
# RAG_WEAVIATE_AUTH_TYPE=none          # none | api_key | bearer
# RAG_WEAVIATE_API_KEY=                # only needed when AUTH_TYPE=api_key
# RAG_WEAVIATE_BEARER_TOKEN=           # only needed when AUTH_TYPE=bearer

# ── Retrieval ──────────────────────────────────────────────────────────────
RAG_RETRIEVER=vector                   # vector | bm25
RAG_TOP_K=2
RAG_EMBED_MODEL=BAAI/bge-small-en-v1.5

# Hybrid (Weaviate): alpha 0..1 — higher = more weight on dense vector vs BM25
RAG_HYBRID_ALPHA=0.75
# Oversample factor: initial retrieval = oversample * TOP_K before dedupe/rerank
RAG_RETRIEVE_OVERSAMPLE=4

# ── Context pipeline (Flask: set RAG_CONTEXT_PIPELINE=true) ────────────────
RAG_CONTEXT_PIPELINE=false
RAG_PIPELINE_DEBUG=true
RAG_DEDUPE_JACCARD=0.88
RAG_RERANK_CHAR_CAP=512
RAG_MEMORY_DECAY_LAMBDA=0.12
RAG_MEMORY_USE_TS=true
RAG_COMPRESSION_TARGET=0.55
RAG_COMPRESSION_MIN_SENT=1
RAG_MODEL_CONTEXT_TOKENS=3000
RAG_MAX_OUTPUT_TOKENS=256
RAG_TOKEN_FRAC_SYSTEM=0.12
RAG_TOKEN_FRAC_HISTORY=0.18
RAG_TOKEN_FRAC_DOCS=0.58
RAG_TOKEN_FRAC_QUERY=0.12

# ── Chunking ───────────────────────────────────────────────────────────────
RAG_CHUNK_CHARS=1200
RAG_CHUNK_OVERLAP=200

# ── Paths ──────────────────────────────────────────────────────────────────
RAG_DOCS_DIR=docs
