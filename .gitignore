# ─────────────────────────────────────────────────────────────────────────────
# .gitignore for CodeSentinel AI / RAG Model workspace
# ─────────────────────────────────────────────────────────────────────────────

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
pip-wheel-metadata/
*.whl

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Environment / Secrets ─────────────────────────────────────────────────────
.env
.env.*
*.env
!.env.example

# ── SQLite databases ──────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Streamlit ─────────────────────────────────────────────────────────────────
.streamlit/secrets.toml

# ── VS Code ───────────────────────────────────────────────────────────────────
.vscode/

# ── Node / npm ────────────────────────────────────────────────────────────────
node_modules/
package-lock.json
npm-debug.log*

# ── OS artifacts ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
*.log.*
server_log.txt
server_out.txt
server_err.txt

# ── Test / Coverage ───────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
test-results/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Docker ────────────────────────────────────────────────────────────────────
docker-compose.override.yml

# ── Weaviate ──────────────────────────────────────────────────────────────────
weaviate_data/
.weaviate_meta.json

# ── Misc ──────────────────────────────────────────────────────────────────────
scratch/
.claude/
